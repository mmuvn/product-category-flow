{
  "info": {
    "name": "TreeShop Ticket API",
    "description": "API endpoints for the Ticket System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Ticket",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"title\": \"My bonsai tree is turning yellow\",\r\n    \"detail\": \"I watered it yesterday but the leaves are falling off.\",\r\n    \"ticketType\": \"PLANT_CARE\",\r\n    \"priority\": \"HIGH\",\r\n    \"creatorId\": 1\r\n}"
        },
        "url": {
          "raw": "http://localhost:8081/api/tickets",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "tickets"
          ]
        }
      }
    },
    {
      "name": "2. Get Customer Tickets",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8081/api/tickets/customer/1",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "tickets",
            "customer",
            "1"
          ]
        }
      }
    },
    {
      "name": "3. Get Pending Queue",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8081/api/tickets/queue",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "tickets",
            "queue"
          ]
        }
      }
    },
    {
      "name": "4. Get Ticket By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8081/api/tickets/1",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "tickets",
            "1"
          ]
        }
      }
    },
    {
      "name": "5. Update Ticket Status",
      "request": {
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "http://localhost:8081/api/tickets/1/status?newState=RESOLVED&agentId=2",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "tickets",
            "1",
            "status"
          ],
          "query": [
            {
              "key": "newState",
              "value": "RESOLVED"
            },
            {
              "key": "agentId",
              "value": "2"
            }
          ]
        }
      }
    }
  ]
}